<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.ajay.controllers.DashboardController">
    
    <top>
        <HBox style="-fx-background-color: #2c3e50; -fx-padding: 10;" alignment="CENTER_RIGHT" spacing="10">
            <Label text="Grocery Shop Dashboard" style="-fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="usernameLabel" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
            <Button fx:id="logoutButton" text="Logout" style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
        </HBox>
    </top>
    
    <left>
        <VBox style="-fx-background-color: #34495e; -fx-min-width: 200;" spacing="10">
            <padding><Insets top="20" right="10" bottom="20" left="10"/></padding>
            
            <Button text="Dashboard" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-min-width: 180; -fx-alignment: CENTER_LEFT;"/>
            <Button text="Products" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-min-width: 180; -fx-alignment: CENTER_LEFT;" onAction="#showProducts"/>
            <Button text="Prices" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-min-width: 180; -fx-alignment: CENTER_LEFT;" onAction="#showPrices"/>
            <Button text="Customers" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-min-width: 180; -fx-alignment: CENTER_LEFT;" onAction="#showCustomers"/>
            <Button text="Billing" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-min-width: 180; -fx-alignment: CENTER_LEFT;" onAction="#showBilling"/>
            <Button text="Inventory" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-min-width: 180; -fx-alignment: CENTER_LEFT;" onAction="#showInventory"/>
            <Button text="Reports" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-min-width: 180; -fx-alignment: CENTER_LEFT;" onAction="#showReports"/>
            <Button text="Settings" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-min-width: 180; -fx-alignment: CENTER_LEFT;" onAction="#showSettings"/>
        </VBox>
    </left>
    
    <center>
        <StackPane fx:id="contentPane" style="-fx-padding: 20;">
            <!-- Default dashboard content -->
            <VBox spacing="20" alignment="TOP_CENTER">
                <Text text="Dashboard Overview" style="-fx-font-size: 24; -fx-font-weight: bold;"/>
                
                <HBox spacing="20" alignment="CENTER">
                    <!-- Summary Cards -->
                    <VBox style="-fx-background-color: #ecf0f1; -fx-background-radius: 5; -fx-padding: 15; -fx-spacing: 5; -fx-min-width: 200;">
                        <Text text="Today's Sales" style="-fx-font-size: 16; -fx-font-weight: bold;"/>
                        <Text fx:id="todaySalesText" text="₹0" style="-fx-font-size: 24; -fx-fill: #27ae60;"/>
                    </VBox>
                    
                    <VBox style="-fx-background-color: #ecf0f1; -fx-background-radius: 5; -fx-padding: 15; -fx-spacing: 5; -fx-min-width: 200;">
                        <Text text="Low Stock Alerts" style="-fx-font-size: 16; -fx-font-weight: bold;"/>
                        <Text fx:id="lowStockText" text="0 Items" style="-fx-font-size: 24; -fx-fill: #e74c3c;"/>
                    </VBox>
                    
                    <VBox style="-fx-background-color: #ecf0f1; -fx-background-radius: 5; -fx-padding: 15; -fx-spacing: 5; -fx-min-width: 200;">
                        <Text text="Recent Transactions" style="-fx-font-size: 16; -fx-font-weight: bold;"/>
                        <Text fx:id="recentTransactionsText" text="0" style="-fx-font-size: 24; -fx-fill: #3498db;"/>
                    </VBox>
                </HBox>
                
                <VBox spacing="10" style="-fx-padding: 20; -fx-min-width: 600;">
                    <Text text="Quick Actions" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
                    <HBox spacing="15">
                        <Button text="New Sale" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-min-width: 120;" onAction="#startNewSale"/>
                        <Button text="Add Product" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-min-width: 120;" onAction="#addNewProduct"/>
                        <Button text="New Customer" style="-fx-background-color: #9b59b6; -fx-text-fill: white; -fx-font-weight: bold; -fx-min-width: 120;" onAction="#addNewCustomer"/>
                    </HBox>
                </VBox>
                
                <VBox spacing="10" style="-fx-padding: 20; -fx-min-width: 600;">
                    <Text text="Recent Activity" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
                    <ListView fx:id="activityListView" style="-fx-min-height: 150; -fx-max-height: 150;">
                        <placeholder>
                            <Label text="No recent activity"/>
                        </placeholder>
                    </ListView>
                </VBox>
            </VBox>
        </StackPane>
    </center>
    
    <bottom>
        <HBox style="-fx-background-color: #ecf0f1; -fx-padding: 5;" spacing="20" alignment="CENTER_LEFT">
            <Label fx:id="statusLabel" text="Status: Connected"/>
            <Label fx:id="lastSyncLabel" text="Last Sync: Just now"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="©2023 Grocery Shop Management System"/>
        </HBox>
    </bottom>
</BorderPane>