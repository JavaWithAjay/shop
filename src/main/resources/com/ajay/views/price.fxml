<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.ajay.controllers.PriceController" spacing="10" style="-fx-padding: 20;">
    
    <Label text="Price Management" style="-fx-font-size: 24; -fx-font-weight: bold;"/>
    
    <HBox spacing="20" alignment="CENTER_LEFT">
        <Label text="Search:"/>
        <TextField fx:id="searchField" promptText="Search products..." style="-fx-min-width: 200;"/>
        
        <Label text="Filter:"/>
        <ComboBox fx:id="filterCombo" style="-fx-min-width: 150;" onAction="#handleFilterOther"/>
        
        <Label text="Price Type:"/>
        <ComboBox fx:id="priceTypeCombo" style="-fx-min-width: 150;" onAction="#handlePriceTypeChange"/>
        
        <Button text="Search" onAction="#handleSearch" style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
    </HBox>
    
    <TableView fx:id="priceTable" style="-fx-max-height: 300;">
        <columns>
            <TableColumn text="ID" fx:id="idCol" minWidth="50"/>
            <TableColumn text="Product" fx:id="nameCol" minWidth="200"/>
            <TableColumn text="Unit" fx:id="unitCol" minWidth="100"/>
            <TableColumn text="Distributor" fx:id="distributorCol" minWidth="100"/>
            <TableColumn text="Wholesale" fx:id="wholesaleCol" minWidth="100"/>
            <TableColumn text="Retail" fx:id="retailCol" minWidth="100"/>
            <TableColumn text="Customer" fx:id="customerCol" minWidth="100"/>
        </columns>
    </TableView>
    
    <HBox spacing="20" alignment="CENTER_LEFT">
        <Label text="Unit:"/>
        <ComboBox fx:id="unitCombo" style="-fx-min-width: 150;" onAction="#handleUnitOther"/>
    </HBox>
    
    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints halignment="RIGHT" minWidth="100"/>
            <ColumnConstraints halignment="LEFT" minWidth="200"/>
        </columnConstraints>
        
        <Label text="Distributor Price:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="distributorPriceField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
        
        <Label text="Wholesale Price:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="wholesalePriceField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
        
        <Label text="Retail Price:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="retailPriceField" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
        
        <Label text="Customer Price:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="customerPriceField" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
    </GridPane>
    
    <HBox spacing="20" alignment="CENTER">
        <Button text="Add" fx:id="addButton" onAction="#handleAddPrice" 
               style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-min-width: 100;"/>
        <Button text="Update" fx:id="updateButton" onAction="#handleUpdatePrice" 
               style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-min-width: 100;"/>
        <Button text="Delete" fx:id="deleteButton" onAction="#handleDeletePrice" 
               style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-min-width: 100;"/>
    </HBox>
</VBox>